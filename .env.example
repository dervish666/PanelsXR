# Komga connection — used from v1 onward (v0 reads synthetic/local pages only).
#
# SECURITY NOTE: anything with a VITE_ prefix is inlined into the client bundle
# and is therefore visible to anyone who opens devtools. Prefer serving the app
# same-origin behind your Komga reverse proxy, or proxying via a Cloudflare
# Worker that holds the key server-side, rather than shipping a real API key here.
VITE_KOMGA_URL=https://komga.example.com
VITE_KOMGA_API_KEY=your-komga-api-key
