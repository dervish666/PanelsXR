# Komga connection — copy to .env.local and fill in (never committed).
#
# Deliberately NOT VITE_-prefixed: these are read only by the Vite dev server,
# which proxies /komga/* to the real server and injects the X-API-Key header
# server-side. The key never reaches the client bundle, and the browser only
# sees same-origin URLs (so no CORS config needed on Komga either).
#
# Generate a key in Komga → Account Settings → API Keys.
KOMGA_URL=https://komga.example.com
KOMGA_API_KEY=your-komga-api-key
